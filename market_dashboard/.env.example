# API keys — DO NOT commit this file to git after filling in
# Copy this file to `.env` and fill in your real keys.

# REQUIRED
FRED_API_KEY=your_fred_key_here
EIA_API_KEY=your_eia_key_here

# OPTIONAL (for news triage)
ANTHROPIC_API_KEY=your_anthropic_key_here
ENABLE_NEWS_TRIAGE=true

# OPTIONAL (for phone alerts via Pushover; recommended)
# Sign up at https://pushover.net, install the app on your phone (~$5 one-time),
# then create an Application to get a token.
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# OPTIONAL (alternate: Twilio SMS — used only if Pushover is not configured)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543

# Optional tuning
CACHE_HOURS=12
HISTORY_YEARS=10
